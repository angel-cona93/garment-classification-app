# ── Model Provider ──────────────────────────────────────
# Choose one: claude | openai | ollama
MODEL_PROVIDER=ollama

# ── Claude (default) ───────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ── OpenAI ─────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Ollama (local) ─────────────────────────────────────
# Run Ollama on your host machine, Docker connects via host.docker.internal
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llava
